experiment:
  name: "experiment_XXX"
  date: "YYYY-MM-DD"
  description: "Brief description of experiment goals and changes"

environment:
  platform: "Lambda Labs A10"
  gpu_memory: "24GB"
  python_version: "3.9"
  base_model: "openai/whisper-XXX"
  optimizations:
    gradient_checkpointing: true
    fp16: true
    sdpa: true
    disk_space_required: "50GB"

dataset:
  source: "pauljunsukhan/throatmic_codered"
  total_examples: 0
  splits:
    train: 0        # ~72% of total
    validation: 0   # ~8% of total
    test: 0         # ~20% of total
  audio:
    sampling_rate: 16000
    min_duration: "0.0625 seconds"  # 1000 samples
    max_duration: "30 seconds"      # 480000 samples
    format: "throat microphone"

training:
  batch_size:
    per_device: 0
    gradient_accumulation_steps: 0
    effective_batch: 0
  learning_rate: 0.0
  warmup_steps: 0
  max_steps: 0     # Calculate based on epochs
  evaluation:
    strategy: "steps"
    eval_steps: 50
    save_steps: 50
    save_total_limit: 5
  regularization:
    weight_decay: 0.01
    dropout: 0.1
    attention_dropout: 0.1
    label_smoothing: 0.1
    max_grad_norm: 0.5
  early_stopping:
    patience: 3
    threshold: 0.01

generation:
  task: "transcribe"
  language: "english"
  max_length: 225
  temperature:
    values: [0.0, 0.2, 0.4]
    strategy: "fallback"
  beam_search:
    num_beams: 5
    length_penalty: 1.0
    repetition_penalty: 1.2
    no_repeat_ngram_size: 3
  thresholds:
    compression_ratio: 1.5
    no_speech: 0.8
    logprob: -1.0

evaluation:
  primary_metric: "WER"
  validation_frequency: "every 50 steps"
  baseline: 0.0            # To be filled after running
  final: 0.0              # To be filled after running
  improvement: 0.0        # To be filled after running 